<SearchPlugin xmlns="http://www.mozilla.org/2006/browser/search/">
<ShortName>SuchHier</ShortName>
<Image width="16" height="16">data:image/png;base64,</Image>
<Url type="application/x-suggestions+json" template="https://m.instantsearch.net/suggest">
    <Param name="q" value="{searchTerms}"/>
    <Param name="rtag" value="sh"/>
    <Param name="fmt" value="rch2"/>
</Url>
<Url type="text/html" method="GET" template="https://suchhier.de/search/">
    <Param name="q" value="{searchTerms}"/>
    <Param name="utm_source" value="shapan"/>
</Url>
<SearchForm>https://suchhier.de/search/</SearchForm>
</SearchPlugin>
